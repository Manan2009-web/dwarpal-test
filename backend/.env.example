# Required: local + Render
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://USERNAME:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/dwarpal?tls=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://10.118.50.198:5173,http://localhost:4173,http://127.0.0.1:4173,https://dwarpal-test.vercel.app
SERVER_URL=http://localhost:5000
# Add any extra frontend origins as a comma-separated list. Keep this in sync with the deployed frontend URLs.

# Optional: local development only
ENABLE_IN_MEMORY_DB=false
AUTO_BOOTSTRAP_SYSTEM_ACCOUNTS=true
# Set AUTO_BOOTSTRAP_SYSTEM_ACCOUNTS=false on Render unless you intentionally want first-run system-account seeding.
DEFAULT_ADMIN_PASSWORD=change_me_if_bootstrap_is_enabled
SEED_ADMIN_KEY=seed-dwarpal-2026

# Optional auth/runtime tuning
BCRYPT_SALT_ROUNDS=10
COOKIE_NAME=dwarpal_token
COOKIE_MAX_AGE_MS=604800000
QR_SIGN_SECRET=replace_with_a_long_random_qr_signing_secret
DEFAULT_HOD_PROGRAM=Degree
DEFAULT_HOD_DEPARTMENT=Computer Engineering
DEFAULT_COORDINATOR_SEMESTER=6
DEFAULT_PHONE_COUNTRY_CODE=+91
COLLEGE_NAME=Your College Name
TRUST_PROXY=false
OTP_SECRET=replace_with_a_long_random_otp_secret

# Email OTP delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=DwarPal
SMTP_FROM_EMAIL=no-reply@example.com

# OTP behavior
REGISTER_OTP_EXPIRY_MINUTES=5
REGISTER_OTP_RESEND_COOLDOWN_SECONDS=45
REGISTER_OTP_RESEND_LIMIT=5
REGISTER_OTP_VERIFY_ATTEMPT_LIMIT=5
PASSWORD_RESET_OTP_EXPIRY_MINUTES=5
PASSWORD_RESET_OTP_RESEND_COOLDOWN_SECONDS=45
PASSWORD_RESET_OTP_VERIFY_ATTEMPT_LIMIT=5

# Firebase Admin for push notifications
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
# Or provide the full service account as JSON/base64 instead of the three values above:
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional web push feature flag.
# Default should be false. When false, missing FIREBASE_WEB_* values will NOT block backend startup.
ENABLE_WEB_PUSH=false

# Public Firebase Web config served by backend at /api/public/frontend-config (public, not secret).
# Required only when ENABLE_WEB_PUSH=true. Keep these least-privilege and origin-restricted provider-side.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=
FIREBASE_WEB_VAPID_KEY=

# HTTP/API safety timeouts
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000

# Student gatepass escalation sweep
GATEPASS_ESCALATION_TIMEOUT_MINUTES=5
GATEPASS_ESCALATION_SWEEP_INTERVAL_MS=60000

# Legacy compatibility
# MONGODB_URI is also supported, but prefer MONGO_URI.
