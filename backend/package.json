{
  "name": "dwarpal-backend",
  "version": "1.0.0",
  "description": "Production-style backend for the DwarPal digital college gatepass system",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "start": "node src/server.js",
    "seed:admins": "node src/seed/seedAdmins.js",
    "seed:system": "node src/seed/bootstrapSystemData.js",
    "migrate:gatepass-ids": "node src/seed/migrateGatepassIds.js",
    "check": "node --check src/server.js && node --check src/app.js"
  },
  "keywords": [
    "dwarpal",
    "express",
    "mongodb",
    "gatepass",
    "college"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.12.1",
    "multer": "^2.0.0",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
